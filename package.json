{
  "name": "powerloom-erp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:int:watch": "vitest --config vitest.integration.config.ts",
    "test:all": "pnpm test:run && pnpm test:integration",
    "db:test:up": "docker compose up -d db-test",
    "migrate": "drizzle-kit push",
    "migrate:generate": "drizzle-kit generate",
    "lint": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "gen:migration": "tsx scripts/gen-migration.ts",
    "gen:module": "tsx scripts/gen-module.ts",
    "gen:test": "tsx scripts/gen-test.ts",
    "gen:endpoint": "tsx scripts/gen-endpoint.ts",
    "gen:seed": "tsx scripts/gen-seed.ts",
    "gen:translation": "tsx scripts/gen-translation.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  }
}
